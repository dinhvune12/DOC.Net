<Window x:Class="Duanlamchung.DashboardLeTan"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Duanlamchung"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Receptionist Dashboard"
        Height="720"
        Width="1100"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        SnapsToDevicePixels="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            CornerRadius="18"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border CornerRadius="18" Background="#FFFFFF">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26" ShadowDepth="0" Opacity="0.28"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER BAR -->
            <Grid Grid.Row="0" Background="#FFFFFF" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Border Width="28" Height="28" CornerRadius="10" Background="#EEF2FF">
                        <Viewbox Margin="6">
                            <Path Fill="#2563EB" Data="M12,2 L2,7 L2,20 C2,21.1 2.9,22 4,22 L20,22 C21.1,22 22,21.1 22,20 L22,7 L12,2 Z M12,5 L20,9 L20,20 L4,20 L4,9 L12,5 Z"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="Hotel Manager" Foreground="#0F172A" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0"/>
                    <TextBlock Text="| Lễ Tân" Foreground="#64748B" FontSize="12" Margin="8,1,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0"/>
            </Grid>

            <!-- MAIN CONTENT -->
            <Border Grid.Row="1" Background="#F8FAFC">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- SIDEBAR -->
                    <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                        <StackPanel Margin="16,20,16,20">
                            <TextBlock Text="Menu"
                                       Foreground="#0F172A"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <Button x:Name="btnDashboard"
                                    Content="Dashboard"
                                    Background="Transparent"
                                    Foreground="#0F172A"
                                    Margin="0,0,0,6"
                                    Height="40"
                                    HorizontalAlignment="Stretch"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="btnDashboard_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button x:Name="btnRoomMap"
                                    Content="Room Map"
                                    Background="Transparent"
                                    Foreground="#0F172A"
                                    Margin="0,0,0,6"
                                    Height="40"
                                    HorizontalAlignment="Stretch"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="btnRoomMap_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button x:Name="btnBooking"
                                    Content="Tạo Đặt Phòng"
                                    Background="Transparent"
                                    Foreground="#0F172A"
                                    Margin="0,0,0,6"
                                    Height="40"
                                    HorizontalAlignment="Stretch"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="btnBooking_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button x:Name="btnBookingList"
                                    Content="Danh Sách Đặt Phòng"
                                    Background="Transparent"
                                    Foreground="#0F172A"
                                    Margin="0,0,0,6"
                                    Height="40"
                                    HorizontalAlignment="Stretch"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="btnBookingList_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button x:Name="btnCheckInOut"
                                    Content="Check-in / Check-out"
                                    Background="Transparent"
                                    Foreground="#0F172A"
                                    Margin="0,0,0,6"
                                    Height="40"
                                    HorizontalAlignment="Stretch"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="btnCheckInOut_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button x:Name="btnRoom"
                                    Content="Quản Lý Phòng"
                                    Background="Transparent"
                                    Foreground="#0F172A"
                                    Margin="0,0,0,20"
                                    Height="40"
                                    HorizontalAlignment="Stretch"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="btnRoom_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Separator Background="#E2E8F0" Margin="0,10,0,10"/>

                            <Button x:Name="btnLogout"
                                    Content="Đăng Xuất"
                                    Background="#FEF2F2"
                                    Foreground="#991B1B"
                                    Height="40"
                                    HorizontalAlignment="Stretch"
                                    BorderBrush="#FECACA"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    Click="btnLogout_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8"
                                                Padding="12,8">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.94"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- CONTENT AREA -->
                    <Grid Grid.Column="1" Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- HEADER -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="Receptionist Dashboard"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#0F172A"/>
                            <TextBlock Text="Quản lý phòng và đặt phòng"
                                       FontSize="13"
                                       Foreground="#64748B"
                                       Margin="0,6,0,0"/>
                        </StackPanel>

                        <!-- STATISTICS -->
                        <UniformGrid Grid.Row="1"
                                     Columns="4"
                                     Margin="0,0,0,20">

                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Margin="8" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Available Rooms" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="txtAvailableRooms"
                                               Text="12"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="#059669"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Margin="8" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Occupied Rooms" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="txtOccupiedRooms"
                                               Text="18"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="#DC2626"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Margin="8" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Today Check-in" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="txtTodayCheckIn"
                                               Text="7"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="#2563EB"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Margin="8" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Today Check-out" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="txtTodayCheckOut"
                                               Text="5"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="#F59E0B"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                        </UniformGrid>

                        <!-- QUICK ACTIONS -->
                        <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,0">
                            <Button x:Name="btnOpenRoomMap"
                                    Content="Open Room Map"
                                    Background="#2563EB"
                                    Foreground="White"
                                    Height="50"
                                    Margin="8"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Click="btnOpenRoomMap_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.94"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button x:Name="btnCreateBooking"
                                    Content="Create Booking"
                                    Background="#059669"
                                    Foreground="White"
                                    Height="50"
                                    Margin="8"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Click="btnCreateBooking_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.94"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button x:Name="btnQuickCheckInOut"
                                    Content="Check-in / Check-out"
                                    Background="#F59E0B"
                                    Foreground="White"
                                    Height="50"
                                    Margin="8"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Click="btnQuickCheckInOut_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.94"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </UniformGrid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>