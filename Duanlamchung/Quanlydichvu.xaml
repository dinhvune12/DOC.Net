<Window x:Class="Duanlamchung.Quanlydichvu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Duanlamchung"
        mc:Ignorable="d"
        Title="Quanlydichvu" Height="450" Width="800">
    <TabControl Margin="10">
        <TabItem Header="Quan lý Dịch vụ">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
                    <TextBox x:Name="txtServiceName" Width="150" Margin="5" Tag="Tên dịch vụ"/>
                    <TextBox x:Name="txtPrice" Width="100" Margin="5" Tag="Đơn giá"/>
                    <CheckBox x:Name="chkActive" Content="Kích hoạt" VerticalAlignment="Center" IsChecked="True" Margin="5"/>
                    <Button Content="Thêm Dịch Vụ" Margin="5" Padding="10,0" Click="btnAddService_Click"/>
                </StackPanel>

                <DataGrid Grid.Row="1" x:Name="dgServices" AutoGenerateColumns="True" Background="#F8F9FA"/>
            </Grid>
        </TabItem>

        <TabItem Header="Tài khoản Lễ tân">
            <Grid Margin="10">
                <StackPanel Width="300" HorizontalAlignment="Left">
                    <TextBlock Text="Tạo tài khoản mới" FontSize="16" Margin="0,0,0,10"/>
                    <TextBlock Text="Tên đăng nhập:"/>
                    <TextBox x:Name="txtUsername" Margin="0,5,0,10" Padding="5"/>
                    <TextBlock Text="Mật khẩu:"/>
                    <PasswordBox x:Name="txtPassword" Margin="0,5,0,10" Padding="5"/>
                    <TextBlock Text="Nhập lại mật khẩu:"/>
                    <PasswordBox x:Name="txtConfirmPassword" Margin="0,5,0,10" Padding="5"/>
                    <TextBlock Text="Họ tên nhân viên:"/>
                    <TextBox x:Name="txtFullName" Margin="0,5,0,15" Padding="5"/>
                    <Button Content="Tạo Tài Khoản" Background="#17A2B8" Foreground="White" Padding="10" Click="btnCreateAccount_Click"/>
                </StackPanel>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
