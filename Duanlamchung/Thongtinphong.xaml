<Window x:Class="Duanlamchung.Thongtinphong"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Duanlamchung"
        mc:Ignorable="d"
        Title="Thongtinphong" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,20,0">
            <TextBlock Text="Thông Tin Phòng" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
            <TextBlock Text="Số Phòng:"/>
            <TextBox x:Name="txtRoomNumber" Margin="0,5,0,10" Padding="5"/>
            <TextBlock Text="Loại Phòng:"/>
            <ComboBox x:Name="cbRoomType" Margin="0,5,0,10" Padding="5">
                <ComboBoxItem Content="Phòng Đơn"/>
                <ComboBoxItem Content="Phòng Đôi"/>
                <ComboBoxItem Content="Vip"/>
            </ComboBox>
            <TextBlock Text="Trạng Thái:"/>
            <ComboBox x:Name="cbStatus" Margin="0,5,0,15" Padding="5">
                <ComboBoxItem Content="Trống"/>
                <ComboBoxItem Content="Đang sử dụng"/>
                <ComboBoxItem Content="Đang sửa chữa"/>
            </ComboBox>
            <Button Content="Thêm Mới" Background="#28A745" Foreground="White" Margin="0,5" Padding="10" Click="btnAdd_Click"/>
            <Button Content="Cập Nhật" Background="#007BFF" Foreground="White" Margin="0,5" Padding="10" Click="btnUpdate_Click"/>
            <Button Content="Xóa Phòng" Background="#DC3545" Foreground="White" Margin="0,5" Padding="10" Click="btnDelete_Click"/>
        </StackPanel>
        <DataGrid Grid.Column="1" x:Name="dgRooms" AutoGenerateColumns="False" CanUserAddRows="False" Background="White" SelectionChanged="dgRooms_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Số Phòng" Binding="{Binding RoomNumber}" Width="100"/>
                <DataGridTextColumn Header="Loại Phòng" Binding="{Binding Type}" Width="*"/>
                <DataGridTextColumn Header="Trạng Thái" Binding="{Binding Status}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
