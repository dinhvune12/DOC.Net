<Window x:Class="Duanlamchung.RegisterCustomer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng ký khách" Height="420" Width="520"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ĐĂNG KÝ KHÁCH" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Họ tên"/>
            <TextBox x:Name="txtName" Grid.Row="0" Margin="0,22,0,10" Height="30"/>

            <TextBlock Grid.Row="1" Text="SĐT"/>
            <TextBox x:Name="txtPhone" Grid.Row="1" Margin="0,22,0,10" Height="30"/>

            <TextBlock Grid.Row="2" Text="CCCD"/>
            <TextBox x:Name="txtCccd" Grid.Row="2" Margin="0,22,0,10" Height="30"/>

            <TextBlock Grid.Row="3" Text="Email"/>
            <TextBox x:Name="txtEmail" Grid.Row="3" Margin="0,22,0,10" Height="30"/>

            <TextBlock Grid.Row="4" Text="Địa chỉ"/>
            <TextBox x:Name="txtAddress" Grid.Row="4" Margin="0,22,0,0" Height="30"/>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Lưu" Width="110" Height="34" Margin="0,0,8,0"
                    Click="btnSave_Click"/>
            <Button Content="Đóng" Width="110" Height="34"
                    Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>