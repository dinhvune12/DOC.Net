<Window x:Class="Duanlamchung.BillPay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:Duanlamchung"
        mc:Ignorable="d"
        Title="Hoa Don / Thanh Toan"
        Height="850"
        Width="1300"
        MinWidth="1100"
        MinHeight="750"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        SnapsToDevicePixels="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            CornerRadius="18"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border CornerRadius="18" Background="#FFFFFF">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26" ShadowDepth="0" Opacity="0.28"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Grid Grid.Row="0" Background="#FFFFFF" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Border Width="28" Height="28" CornerRadius="10" Background="#EEF2FF">
                        <Viewbox Margin="6">
                            <Path Fill="#2563EB" Data="M12,2 L2,7 L2,20 C2,21.1 2.9,22 4,22 L20,22 C21.1,22 22,21.1 22,20 L22,7 L12,2 Z M12,5 L20,9 L20,20 L4,20 L4,9 L12,5 Z"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="Hotel Manager" Foreground="#0F172A" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0"/>
                    <TextBlock Text="Hoa Don" Foreground="#64748B" FontSize="12" Margin="8,1,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Button Width="40" Height="30" Margin="0,0,6,0"
                            Background="#F1F5F9" BorderBrush="#E2E8F0" Foreground="#0F172A"
                            Click="BtnMinimize_Click">
                        <TextBlock Text="-" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Width="40" Height="30"
                            Background="#FEF2F2" BorderBrush="#FECACA" Foreground="#991B1B"
                            Click="BtnClose_Click">
                        <TextBlock Text="X" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="1" Background="#F8FAFC" Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Hoa Don / Thanh Toan" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Quan ly va thanh toan hoa don cua khach hang" FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- FORM -->
                <Border Grid.Row="1" Background="White" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: SEARCH & FILTER -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,20">
                            <TextBlock Text="Tim kiem hoa don" FontSize="14" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Ma booking / So hoa don" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="txtSearch" Height="36" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12,0" VerticalContentAlignment="Center" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="12,0,12,0">
                                    <TextBlock Text="Trang thai" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="cbStatus" Height="36" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12,6" FontSize="13">
                                        <ComboBoxItem Content="Tat ca"/>
                                        <ComboBoxItem Content="Cho thanh toan"/>
                                        <ComboBoxItem Content="Da thanh toan"/>
                                        <ComboBoxItem Content="Huy"/>
                                    </ComboBox>
                                </StackPanel>
                                <Button Grid.Column="2" Content="Tim kiem" Width="90" Height="36" Background="#2563EB" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Bottom" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="12,8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <!-- BILLS LIST -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,16">
                            <TextBlock Text="Danh sach hoa don" FontSize="13" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,8"/>
                            <DataGrid x:Name="dgBills"
                                      Height="200"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionChanged="dgBills_SelectionChanged"
                                      RowHeight="32"
                                      GridLinesVisibility="None"
                                      AlternationCount="2">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#64748B"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="8,0,8,8"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                        <Setter Property="FontSize" Value="11"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="White"/>
                                        <Style.Triggers>
                                            <Trigger Property="AlternationIndex" Value="1">
                                                <Setter Property="Background" Value="#F9FAFB"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#DBEAFE"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="So HD" Binding="{Binding BillNumber}" Width="80"/>
                                    <DataGridTextColumn Header="Ma Booking" Binding="{Binding BookingId}" Width="80"/>
                                    <DataGridTextColumn Header="Khach" Binding="{Binding CustomerName}" Width="*"/>
                                    <DataGridTextColumn Header="Phong" Binding="{Binding RoomNo}" Width="70"/>
                                    <DataGridTextColumn Header="Tong tien" Binding="{Binding TotalAmount}" Width="100"/>
                                    <DataGridTextColumn Header="Trang thai" Binding="{Binding Status}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>

                        <!-- RIGHT: BILL DETAILS -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                            <TextBlock Text="Chi tiet hoa don" FontSize="14" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,16"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,16,0">
                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="So hoa don" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="txtBillNumber" FontSize="13" Foreground="#0F172A"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="Khach hang" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="txtCustomerName" FontSize="13" Foreground="#0F172A"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="So phong" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="txtRoomNumber" FontSize="13" Foreground="#0F172A"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Ngay tao" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="txtCreateDate" FontSize="13" Foreground="#0F172A"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="Tong tien phong" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="txtRoomTotal" FontSize="13" Foreground="#0F172A"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="Tien dich vu" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="txtServiceTotal" FontSize="13" Foreground="#0F172A"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="Tien thue" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="txtTaxTotal" FontSize="13" Foreground="#0F172A"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,0">
                                        <TextBlock Text="Trang thai" FontSize="11" Forecolor="#64748B" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <Border Padding="8,4" CornerRadius="6" Background="#EEF2FF" Width="100" HorizontalAlignment="Left">
                                            <TextBlock x:Name="txtPaymentStatus" FontSize="12" FontWeight="SemiBold" Foreground="#2563EB"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- TOTAL AMOUNT -->
                        <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Background="#EEF2FF" CornerRadius="12" Padding="16" Margin="0,20,0,0" BorderBrush="#BFDBFE" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tong cong phai thanh toan" FontSize="13" Foreground="#64748B" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBox x:Name="txtTotalPayment" Background="Transparent" BorderThickness="0" Text="0" IsReadOnly="True" FontSize="22" FontWeight="Bold" Foreground="#2563EB" Width="180" TextAlignment="Right" VerticalContentAlignment="Center"/>
                                    <TextBlock Text=" VND" FontSize="13" Foreground="#64748B" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- BUTTONS -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnPrint" Content="In hoa don" Width="110" Height="44" Background="#2563EB" Foreground="White" FontWeight="SemiBold" Margin="0,0,10,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="btnPay" Content="Thanh toan" Width="110" Height="44" Background="#059669" Foreground="White" FontWeight="SemiBold" Margin="0,0,10,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="btnCancel" Content="Huy" Width="110" Height="44" Background="#DC2626" Foreground="White" FontWeight="SemiBold" Margin="0,0,10,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="btnClose" Content="Dong" Width="110" Height="44" Background="#6B7280" Foreground="White" FontWeight="SemiBold" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
