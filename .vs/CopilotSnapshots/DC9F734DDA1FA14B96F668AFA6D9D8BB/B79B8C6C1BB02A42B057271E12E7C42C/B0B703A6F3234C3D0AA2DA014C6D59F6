                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- 104 -->
                            <Border x:Name="bd104" Background="#F3F4F6" Margin="0" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
                                <StackPanel Margin="14">
                                    <TextBlock Text="Room 104" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock x:Name="txtStatus104" Text="Maintenance" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                    <Button x:Name="Btn104" Content="Details" Tag="104" Height="32" Margin="0,10,0,0" Background="#2563EB" Foreground="White" FontWeight="SemiBold" Click="ViewRoom_Click">
