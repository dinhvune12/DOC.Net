                                    <Button x:Name="Btn106" Content="View" Tag="106" Height="32" Margin="0,10,0,0" Background="#2563EB" Foreground="White" FontWeight="SemiBold" Click="ViewRoom_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="8,4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
