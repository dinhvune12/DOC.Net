<Window x:Class="Duanlamchung.RoommapLeTan"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:local="clr-namespace:Duanlamchung"
    mc:Ignorable="d"
    Title="Room Map"
    Height="800"
    Width="1200"
    MinWidth="1000"
    MinHeight="700"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    ResizeMode="CanResize"
    Background="Transparent"
    AllowsTransparency="True"
    SnapsToDevicePixels="True">

<shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="44"
                        CornerRadius="18"
                        GlassFrameThickness="0"
                        ResizeBorderThickness="8"
                        UseAeroCaptionButtons="False"/>
</shell:WindowChrome.WindowChrome>

<Border CornerRadius="18" Background="#FFFFFF">
    <Border.Effect>
        <DropShadowEffect BlurRadius="26" ShadowDepth="0" Opacity="0.28"/>
    </Border.Effect>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0" Background="#FFFFFF" MouseLeftButtonDown="Window_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <Border Width="28" Height="28" CornerRadius="10" Background="#EEF2FF">
                    <Viewbox Margin="6">
                        <Path Fill="#2563EB" Data="M12,2 L2,7 L2,20 C2,21.1 2.9,22 4,22 L20,22 C21.1,22 22,21.1 22,20 L22,7 L12,2 Z M12,5 L20,9 L20,20 L4,20 L4,9 L12,5 Z"/>
                    </Viewbox>
                </Border>
                <TextBlock Text="Hotel Manager" Foreground="#0F172A" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0"/>
                <TextBlock Text="Room Map" Foreground="#64748B" FontSize="12" Margin="8,1,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                <Button Width="40" Height="30" Margin="0,0,6,0"
                        Background="#F1F5F9" BorderBrush="#E2E8F0" Foreground="#0F172A"
                        Click="BtnMinimize_Click">
                    <TextBlock Text="-" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
                <Button Width="40" Height="30"
                        Background="#FEF2F2" BorderBrush="#FECACA" Foreground="#991B1B"
                        Click="BtnClose_Click">
                    <TextBlock Text="X" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1" Background="#F8FAFC" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Room Map" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock Text="Tat ca phong va trang thai hien tai" FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- ROOM GRID -->
            <Border Grid.Row="1" Background="White" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20" Margin="0,0,0,16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <UniformGrid Columns="4">

                            <!-- 101 -->
                            <Border x:Name="bd101" Background="#DBEAFE" Margin="0" CornerRadius="12" BorderBrush="#BFDBFE" BorderThickness="1">
                                <StackPanel Margin="14">
                                    <TextBlock Text="Room 101" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock x:Name="txtStatus101" Text="Available" Foreground="#059669" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                    <Button x:Name="Btn101" Content="Book" Tag="101" Height="32" Margin="0,10,0,0" Background="#2563EB" Foreground="White" FontWeight="SemiBold" Click="BookRoom_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="8,4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- 102 -->
                            <Border x:Name="bd102" Background="#FEE2E2" Margin="0" CornerRadius="12" BorderBrush="#FECACA" BorderThickness="1">
                                <StackPanel Margin="14">
                                    <TextBlock Text="Room 102" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock x:Name="txtStatus102" Text="Occupied" Foreground="#DC2626" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                    <Button x:Name="Btn102" Content="View" Tag="102" Height="32" Margin="0,10,0,0" Background="#2563EB" Foreground="White" FontWeight="SemiBold" Click="ViewRoom_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="8,4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- 103 -->
                            <Border x:Name="bd103" Background="#FEF3C7" Margin="0" CornerRadius="12" BorderBrush="#FCD34D" BorderThickness="1">
                                <StackPanel Margin="14">
                                    <TextBlock Text="Room 103" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock x:Name="txtStatus103" Text="Cleaning" Foreground="#F59E0B" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                    <Button x:Name="Btn103" Content="Update" Tag="103" Height="32" Margin="0,10,0,0" Background="#2563EB" Foreground="White" FontWeight="SemiBold" Click="UpdateRoom_Click">
