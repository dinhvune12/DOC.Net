                                </StackPanel>
                            </Border>

                            <!-- 107 -->
                            <Border x:Name="bd107" Background="#FEF3C7" Margin="0" CornerRadius="12" BorderBrush="#FCD34D" BorderThickness="1">
                                <StackPanel Margin="14">
                                    <TextBlock Text="Room 107" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock x:Name="txtStatus107" Text="Cleaning" Foreground="#F59E0B" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                    <Button x:Name="Btn107" Content="Update" Tag="107" Height="32" Margin="0,10,0,0" Background="#2563EB" Foreground="White" FontWeight="SemiBold" Click="UpdateRoom_Click">
