                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- 110 -->
                            <Border x:Name="bd110" Background="#FEE2E2" Margin="0" CornerRadius="12" BorderBrush="#FECACA" BorderThickness="1">
                                <StackPanel Margin="14">
                                    <TextBlock Text="Room 110" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock x:Name="txtStatus110" Text="Occupied" Foreground="#DC2626" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                    <Button x:Name="Btn110" Content="View" Tag="110" Height="32" Margin="0,10,0,0" Background="#2563EB" Foreground="White" FontWeight="SemiBold" Click="ViewRoom_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="8,4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- 111 -->
                            <Border x:Name="bd111" Background="#FEF3C7" Margin="0" CornerRadius="12" BorderBrush="#FCD34D" BorderThickness="1">
                                <StackPanel Margin="14">
                                    <TextBlock Text="Room 111" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock x:Name="txtStatus111" Text="Cleaning" Foreground="#F59E0B" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                    <Button x:Name="Btn111" Content="Update" Tag="111" Height="32" Margin="0,10,0,0" Background="#2563EB" Foreground="White" FontWeight="SemiBold" Click="UpdateRoom_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="8,4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- 112 -->
                            <Border x:Name="bd112" Background="#F3F4F6" Margin="0" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
                                <StackPanel Margin="14">
                                    <TextBlock Text="Room 112" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock x:Name="txtStatus112" Text="Maintenance" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                    <Button x:Name="Btn112" Content="Details" Tag="112" Height="32" Margin="0,10,0,0" Background="#2563EB" Foreground="White" FontWeight="SemiBold" Click="ViewRoom_Click">
