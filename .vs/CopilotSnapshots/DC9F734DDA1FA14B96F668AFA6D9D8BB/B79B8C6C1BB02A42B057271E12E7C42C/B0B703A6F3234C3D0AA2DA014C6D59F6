                                </StackPanel>
                            </Border>

                            <!-- 109 -->
                            <Border x:Name="bd109" Background="#DBEAFE" Margin="0" CornerRadius="12" BorderBrush="#BFDBFE" BorderThickness="1">
                                <StackPanel Margin="14">
                                    <TextBlock Text="Room 109" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock x:Name="txtStatus109" Text="Available" Foreground="#059669" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                    <Button x:Name="Btn109" Content="Book" Tag="109" Height="32" Margin="0,10,0,0" Background="#2563EB" Foreground="White" FontWeight="SemiBold" Click="BookRoom_Click">
