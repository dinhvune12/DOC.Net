<Window x:Class="Duanlamchung.CheckInOut"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Duanlamchung"
    mc:Ignorable="d"
    Title="Check-in / Check-out" Height="620" Width="1100"
    WindowStartupLocation="CenterScreen"
    Background="#F8FAFC">
<Grid Margin="16">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- HEADER -->
    <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,12" BorderBrush="#E2E8F0" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Check-in / Check-out" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock Text="Quan ly trang thai check-in va check-out cua khach" FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
            </StackPanel>

            <ComboBox x:Name="cbFilter" Grid.Column="1" Width="200" Height="36" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10" SelectedIndex="0" SelectionChanged="cbFilter_SelectionChanged" VerticalAlignment="Center">
                <ComboBoxItem Content="Tat ca"/>
                <ComboBoxItem Content="Cho check-in"/>
                <ComboBoxItem Content="Dang o"/>
                <ComboBoxItem Content="Da check-out"/>
            </ComboBox>
        </Grid>
    </Border>

    <!-- SEARCH -->
    <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="12" Margin="0,0,0,12" BorderBrush="#E2E8F0" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="Tim kiem" FontSize="12" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,6"/>
            <TextBox x:Name="txtSearch" Height="32" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10,0" VerticalContentAlignment="Center" TextChanged="txtSearch_TextChanged" Foreground="#0F172A"/>
        </StackPanel>
    </Border>

    <!-- BODY -->
    <Grid Grid.Row="2" Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: BOOKINGS LIST -->
        <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="12" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Danh sach booking" FontWeight="Bold" FontSize="13" Foreground="#0F172A" Margin="0,0,0,8"/>

                <DataGrid x:Name="dgBookings"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          SelectionChanged="dgBookings_SelectionChanged"
                          RowHeight="36"
                          GridLinesVisibility="None"
                          AlternationCount="2">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,0,8,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Resources>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="#F9FAFB"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DBEAFE"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ma" Binding="{Binding BookingId}" Width="70"/>
                        <DataGridTextColumn Header="Khach" Binding="{Binding CustomerName}" Width="*"/>
                        <DataGridTextColumn Header="Phong" Binding="{Binding RoomNo}" Width="60"/>
                        <DataGridTextColumn Header="Loai" Binding="{Binding RoomType}" Width="80"/>
                        <DataGridTextColumn Header="Check-in" Binding="{Binding CheckInDate}" Width="85"/>
                        <DataGridTextColumn Header="Check-out" Binding="{Binding CheckOutDate}" Width="85"/>
                        <DataGridTextColumn Header="Trang Thai" Binding="{Binding Status}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- RIGHT: DETAIL -->
        <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="16" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Chi tiet" FontWeight="Bold" FontSize="13" Foreground="#0F172A"/>

                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                    <TextBlock Text="Ma booking" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtBookingId" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,10,0,0">
                    <TextBlock Text="Khach" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtCustomer" FontSize="13" Foreground="#0F172A"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,10,0,0">
                    <TextBlock Text="Phong" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtRoom" FontSize="13" Foreground="#0F172A"/>
                </StackPanel>

                <StackPanel Grid.Row="4" Margin="0,10,0,0">
                    <TextBlock Text="Thoi gian" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtDateRange" FontSize="13" Foreground="#0F172A"/>
                </StackPanel>

                <StackPanel Grid.Row="5" Margin="0,10,0,0">
                    <TextBlock Text="Trang thai" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Border Padding="8,4" CornerRadius="6" Background="#EEF2FF" Width="100" HorizontalAlignment="Left">
                        <TextBlock x:Name="txtStatus" FontSize="12" FontWeight="SemiBold" Foreground="#2563EB"/>
                    </Border>
                </StackPanel>


                    <Border Grid.Row="6" Margin="0,12,0,0" Padding="10" CornerRadius="10" Background="#F9FAFB">
                        <StackPanel>
                            <TextBlock Text="Ghi chú nhanh:" Foreground="Gray"/>
                            <TextBox x:Name="txtNote" Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer buttons -->
        <Border Grid.Row="2" Margin="0,10,0,0" Background="#F3F4F6" CornerRadius="10" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="txtHint" VerticalAlignment="Center" Foreground="Gray"
                           Text="Tip: Chọn booking rồi bấm Check-in / Hóa đơn / Check-out."/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnCheckIn" Content="Check-in" Width="110" Height="34" Margin="0,0,8,0"
                            Click="btnCheckIn_Click"/>
                    <Button x:Name="btnInvoice" Content="Hóa đơn" Width="110" Height="34" Margin="0,0,8,0"
                            Click="btnInvoice_Click"/>
                    <Button x:Name="btnCheckOut" Content="Check-out" Width="110" Height="34" Margin="0,0,8,0"
                            Click="btnCheckOut_Click"/>
                    <Button Content="Đóng" Width="90" Height="34" Click="btnClose_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>