<Window x:Class="Duanlamchung.DatphongLeTan"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Tao / Quan ly Dat Phong"
        Height="750"
        Width="1200"
        MinWidth="1000"
        MinHeight="650"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        SnapsToDevicePixels="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            CornerRadius="18"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border CornerRadius="18" Background="#FFFFFF">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26" ShadowDepth="0" Opacity="0.28"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER BAR -->
            <Grid Grid.Row="0" Background="#FFFFFF" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Border Width="28" Height="28" CornerRadius="10" Background="#EEF2FF">
                        <Viewbox Margin="6">
                            <Path Fill="#2563EB" Data="M12,2 L2,7 L2,20 C2,21.1 2.9,22 4,22 L20,22 C21.1,22 22,21.1 22,20 L22,7 L12,2 Z M12,5 L20,9 L20,20 L4,20 L4,9 L12,5 Z"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="Hotel Manager" Foreground="#0F172A" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0"/>
                    <TextBlock Text="Tao Dat Phong" Foreground="#64748B" FontSize="12" Margin="8,1,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Button Width="40" Height="30" Margin="0,0,6,0"
                            Background="#F1F5F9" BorderBrush="#E2E8F0" Foreground="#0F172A"
                            Click="BtnMinimize_Click">
                        <TextBlock Text="---" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Width="40" Height="30"
                            Background="#FEF2F2" BorderBrush="#FECACA" Foreground="#991B1B"
                            Click="BtnClose_Click">
                        <TextBlock Text="X" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- MAIN CONTENT -->
            <Border Grid.Row="1" Background="#F8FAFC" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Tao / Quan ly Dat Phong" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock Text="Them moi hoac chinh sua thong tin dat phong cua khach hang" 
                                   FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- FORM CONTENT -->
                    <Border Grid.Row="1" Background="White" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- LEFT COLUMN: CUSTOMER INFO -->
                            <TextBlock Text="Thong tin khach hang" Grid.Column="0" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,12"/>

                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,12,0">
                                <TextBlock Text="Ho ten" FontSize="12" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="txtFullName"
                                         Background="#F8FAFC"
                                         BorderBrush="#E2E8F0"
                                         BorderThickness="1"
                                         Padding="10,10"
                                         FontSize="13"/>
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,12,12,0">
                                <TextBlock Text="So dien thoai" FontSize="12" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="txtPhone"
                                         Background="#F8FAFC"
                                         BorderBrush="#E2E8F0"
                                         BorderThickness="1"
                                         Padding="10,10"
                                         FontSize="13"/>
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.Row="3" Margin="0,12,12,0">
                                <TextBlock Text="CCCD / Ho chieu" FontSize="12" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="txtIDPassport"
                                         Background="#F8FAFC"
                                         BorderBrush="#E2E8F0"
                                         BorderThickness="1"
                                         Padding="10,10"
                                         FontSize="13"/>
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.Row="4" Margin="0,12,12,0">
                                <TextBlock Text="Ghi chu" FontSize="12" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="txtNote"
                                         Background="#F8FAFC"
                                         BorderBrush="#E2E8F0"
                                         BorderThickness="1"
                                         Padding="10,10"
                                         FontSize="13"
                                         Height="80"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>

                            <!-- RIGHT COLUMN: BOOKING INFO -->
                            <TextBlock Text="Thong tin dat phong" Grid.Column="1" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A" Margin="12,0,0,12"/>

                            <StackPanel Grid.Column="1" Grid.Row="1" Margin="12,0,0,0">
                                <TextBlock Text="Loai phong" FontSize="12" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <ComboBox x:Name="cbRoomType"
                                          Background="#F8FAFC"
                                          BorderBrush="#E2E8F0"
                                          BorderThickness="1"
                                          Padding="10,10"
                                          FontSize="13"
                                          SelectionChanged="DataChanged">
                                    <ComboBoxItem Content="Standard"/>
                                    <ComboBoxItem Content="Deluxe"/>
                                    <ComboBoxItem Content="VIP"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Grid.Row="2" Margin="12,12,0,0">
                                <TextBlock Text="So phong" FontSize="12" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <ComboBox x:Name="cbRoomNumber"
                                          Background="#F8FAFC"
                                          BorderBrush="#E2E8F0"
                                          BorderThickness="1"
                                          Padding="10,10"
                                          FontSize="13"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Grid.Row="3" Margin="12,12,0,0">
                                <TextBlock Text="Check-in" FontSize="12" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <DatePicker x:Name="dpCheckIn"
                                            Background="#F8FAFC"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            Padding="10,10"
                                            SelectedDateChanged="DataChanged"/>
                            </StackPanel>

                            <Grid Grid.Column="1" Grid.Row="4" Margin="12,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Check-out" FontSize="12" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <DatePicker x:Name="dpCheckOut"
                                                Background="#F8FAFC"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                Padding="10,10"
                                                SelectedDateChanged="DataChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="Trang thai" FontSize="12" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="cbStatus"
                                              Background="#F8FAFC"
                                              BorderBrush="#E2E8F0"
                                              BorderThickness="1"
                                              Padding="10,10"
                                              FontSize="13">
                                        <ComboBoxItem Content="Pending"/>
                                        <ComboBoxItem Content="Confirmed"/>
                                        <ComboBoxItem Content="Checked In"/>
                                        <ComboBoxItem Content="Cancelled"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- TOTAL PRICE -->
                    <Border Grid.Row="1" VerticalAlignment="Bottom" Margin="0,16,0,0"
                            Background="#EEF2FF"
                            CornerRadius="12"
                            Padding="16"
                            BorderBrush="#BFDBFE"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Tong tien" FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox x:Name="txtTotalPrice"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Text="0"
                                         IsReadOnly="True"
                                         FontSize="20"
                                         FontWeight="Bold"
                                         Foreground="#2563EB"
                                         TextAlignment="Right"
                                         Width="150"/>
                                <TextBlock Text=" VND" FontSize="13" Foreground="#64748B" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- BUTTONS -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button x:Name="BtnBack"
                                Content="Quay lai"
                                Background="#F1F5F9"
                                Foreground="#0F172A"
                                Width="120"
                                Height="44"
                                FontWeight="SemiBold"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                Margin="0,0,12,0"
                                Cursor="Hand"
                                Click="BtnBack_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.94"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="btnCreate"
                                Content="Tao moi"
                                Background="#2563EB"
                                Foreground="White"
                                Width="120"
                                Height="44"
                                FontWeight="SemiBold"
                                BorderBrush="#1D4ED8"
                                BorderThickness="1"
                                Margin="0,0,12,0"
                                Cursor="Hand"
                                Click="btnCreate_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.94"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="btnUpdate"
                                Content="Cap nhat"
                                Background="#059669"
                                Foreground="White"
                                Width="120"
                                Height="44"
                                FontWeight="SemiBold"
                                BorderBrush="#047857"
                                BorderThickness="1"
                                Margin="0,0,12,0"
                                Cursor="Hand"
                                Click="btnUpdate_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.94"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="btnCancelBooking"
                                Content="Huy"
                                Background="#DC2626"
                                Foreground="White"
                                Width="120"
                                Height="44"
                                FontWeight="SemiBold"
                                BorderBrush="#B91C1C"
                                BorderThickness="1"
                                Margin="0,0,12,0"
                                Cursor="Hand"
                                Click="btnCancelBooking_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.94"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="btnConfirmCheckIn"
                                Content="Check-in"
                                Background="#F59E0B"
                                Foreground="White"
                                Width="120"
                                Height="44"
                                FontWeight="SemiBold"
                                BorderBrush="#D97706"
                                BorderThickness="1"
                                Cursor="Hand"
                                Click="btnConfirmCheckIn_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.94"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Room Type:"/>
                    <ComboBox x:Name="cbRoomType"
                              Grid.Column="1"
                              Margin="5"
                              SelectionChanged="DataChanged">
                        <ComboBoxItem Content="Standard"/>
                        <ComboBoxItem Content="Deluxe"/>
                        <ComboBoxItem Content="VIP"/>
                    </ComboBox>

                    <TextBlock Text="Room Number:" Grid.Row="1"/>
                    <ComboBox x:Name="cbRoomNumber"
                              Grid.Row="1"
                              Grid.Column="1"
                              Margin="5">
                        <ComboBoxItem Content="101"/>
                        <ComboBoxItem Content="102"/>
                        <ComboBoxItem Content="201"/>
                    </ComboBox>

                    <TextBlock Text="Check-in:" Grid.Row="2"/>
                    <DatePicker x:Name="dpCheckIn"
                                Grid.Row="2"
                                Grid.Column="1"
                                Margin="5"
                                SelectedDateChanged="DataChanged"/>

                    <TextBlock Text="Check-out:" Grid.Row="3"/>
                    <DatePicker x:Name="dpCheckOut"
                                Grid.Row="3"
                                Grid.Column="1"
                                Margin="5"
                                SelectedDateChanged="DataChanged"/>

                    <TextBlock Text="Status:" Grid.Row="4"/>
                    <ComboBox x:Name="cbStatus"
                              Grid.Row="4"
                              Grid.Column="1"
                              Margin="5">
                        <ComboBoxItem Content="Pending"/>
                        <ComboBoxItem Content="Confirmed"/>
                        <ComboBoxItem Content="Checked In"/>
                        <ComboBoxItem Content="Cancelled"/>
                    </ComboBox>

                    <TextBlock Text="Total Price:" Grid.Row="5"/>
                    <TextBox x:Name="txtTotalPrice"
                             Grid.Row="5"
                             Grid.Column="1"
                             Margin="5"
                             IsReadOnly="True"
                             Text="0"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- BUTTONS -->
        <Border Grid.Row="2"
                Background="#F5F5F5"
                Padding="15"
                Margin="0,20,0,0"
                CornerRadius="10">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button x:Name="btnCreate"
                        Content="Create"
                        Width="100"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="btnCreate_Click"/>

                <Button x:Name="btnUpdate"
                        Content="Update"
                        Width="100"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="btnUpdate_Click"/>

                <Button x:Name="btnCancelBooking"
                        Content="Cancel Booking"
                        Width="130"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="btnCancelBooking_Click"/>

                <Button x:Name="btnConfirmCheckIn"
                        Content="Confirm / Check-in"
                        Width="160"
                        Height="35"
                        Click="btnConfirmCheckIn_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>