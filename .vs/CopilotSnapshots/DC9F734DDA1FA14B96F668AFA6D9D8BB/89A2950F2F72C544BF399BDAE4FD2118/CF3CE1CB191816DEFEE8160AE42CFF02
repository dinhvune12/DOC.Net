<Window x:Class="Duanlamchung.DatphongLeTan"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Tao / Quan ly Dat Phong"
    Height="700"
    Width="1100"
    WindowStartupLocation="CenterScreen"
    Background="#F8FAFC">

<Grid Margin="16">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,12" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Tao / Quan ly Dat Phong" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Them moi hoac chinh sua thong tin dat phong" FontSize="12" Foreground="#64748B" Margin="0,6,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" x:Name="BtnBack" Content="Quay lai" Width="100" Height="36" Background="#F1F5F9" Foreground="#0F172A" BorderBrush="#E2E8F0" BorderThickness="1" FontWeight="SemiBold" VerticalAlignment="Center" Click="BtnBack_Click"/>
            </Grid>
        </Border>

        <!-- FORM CONTENT -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,12" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- LEFT: CUSTOMER -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Thong tin khach hang" FontSize="14" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,16"/>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Ho ten" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtFullName" Height="32" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10,0" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="So dien thoai" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtPhone" Height="32" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10,0" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="CCCD / Ho chieu" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtIDPassport" Height="32" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10,0" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Ghi chu" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtNote" Height="80" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10,8" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </StackPanel>

                <!-- RIGHT: BOOKING -->
                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                    <TextBlock Text="Thong tin dat phong" FontSize="14" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,16"/>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Loai phong" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <ComboBox x:Name="cbRoomType" Height="32" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10,4" SelectionChanged="DataChanged">
                            <ComboBoxItem Content="Standard"/>
                            <ComboBoxItem Content="Deluxe"/>
                            <ComboBoxItem Content="VIP"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="So phong" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <ComboBox x:Name="cbRoomNumber" Height="32" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10,4">
                            <ComboBoxItem Content="101"/>
                            <ComboBoxItem Content="102"/>
                            <ComboBoxItem Content="201"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Check-in" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <DatePicker x:Name="dpCheckIn" Height="32" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10,4" SelectedDateChanged="DataChanged"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Check-out" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <DatePicker x:Name="dpCheckOut" Height="32" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10,4" SelectedDateChanged="DataChanged"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Trang thai" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <ComboBox x:Name="cbStatus" Height="32" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10,4">
                            <ComboBoxItem Content="Pending"/>
                            <ComboBoxItem Content="Confirmed"/>
                            <ComboBoxItem Content="Checked In"/>
                            <ComboBoxItem Content="Cancelled"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <!-- TOTAL PRICE -->
                <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#EEF2FF" CornerRadius="8" Padding="12" Margin="0,20,0,0" BorderBrush="#BFDBFE" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Tong tien:" FontSize="12" Foreground="#64748B" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="txtTotalPrice" Background="Transparent" BorderThickness="0" Text="0" IsReadOnly="True" FontSize="18" FontWeight="Bold" Foreground="#2563EB" Width="150" TextAlignment="Right" Margin="12,0" VerticalContentAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="VND" FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
            <Button x:Name="btnCreate" Content="Tao moi" Width="100" Height="40" Background="#2563EB" Foreground="White" FontWeight="SemiBold" Margin="0,0,8,0" Click="btnCreate_Click"/>
            <Button x:Name="btnUpdate" Content="Cap nhat" Width="100" Height="40" Background="#059669" Foreground="White" FontWeight="SemiBold" Margin="0,0,8,0" Click="btnUpdate_Click"/>
            <Button x:Name="btnCancelBooking" Content="Huy" Width="100" Height="40" Background="#DC2626" Foreground="White" FontWeight="SemiBold" Margin="0,0,8,0" Click="btnCancelBooking_Click"/>
            <Button x:Name="btnConfirmCheckIn" Content="Check-in" Width="100" Height="40" Background="#F59E0B" Foreground="White" FontWeight="SemiBold" Click="btnConfirmCheckIn_Click"/>
        </StackPanel>
    </Grid>
</Window>