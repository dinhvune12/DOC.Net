<Window x:Class="Duanlamchung.DatphongLeTan"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Tao / Quan ly Dat Phong"
        Height="750"
        Width="1200"
        MinWidth="1000"
        MinHeight="650"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        SnapsToDevicePixels="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            CornerRadius="18"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border CornerRadius="18" Background="#FFFFFF">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26" ShadowDepth="0" Opacity="0.28"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Grid Grid.Row="0" Background="#FFFFFF" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Border Width="28" Height="28" CornerRadius="10" Background="#EEF2FF">
                        <Viewbox Margin="6">
                            <Path Fill="#2563EB" Data="M12,2 L2,7 L2,20 C2,21.1 2.9,22 4,22 L20,22 C21.1,22 22,21.1 22,20 L22,7 L12,2 Z M12,5 L20,9 L20,20 L4,20 L4,9 L12,5 Z"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="Hotel Manager" Foreground="#0F172A" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0"/>
                    <TextBlock Text="Tao Dat Phong" Foreground="#64748B" FontSize="12" Margin="8,1,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Button Width="40" Height="30" Margin="0,0,6,0"
                            Background="#F1F5F9" BorderBrush="#E2E8F0" Foreground="#0F172A"
                            Click="BtnMinimize_Click">
                        <TextBlock Text="-" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Width="40" Height="30"
                            Background="#FEF2F2" BorderBrush="#FECACA" Foreground="#991B1B"
                            Click="BtnClose_Click">
                        <TextBlock Text="X" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="1" Background="#F8FAFC" Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Tao / Quan ly Dat Phong" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Them moi hoac chinh sua thong tin dat phong cua khach hang" FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- FORM -->
                <Border Grid.Row="1" Background="White" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: CUSTOMER -->
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Thong tin khach hang" FontSize="14" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,16"/>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Ho ten" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="txtFullName" Height="36" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12,0" VerticalContentAlignment="Center" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="So dien thoai" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="txtPhone" Height="36" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12,0" VerticalContentAlignment="Center" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="CCCD / Ho chieu" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="txtIDPassport" Height="36" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12,0" VerticalContentAlignment="Center" FontSize="13"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Ghi chu" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="txtNote" Height="100" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12,10" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- RIGHT: BOOKING -->
                        <StackPanel Grid.Column="1" Margin="20,0,0,0">
                            <TextBlock Text="Thong tin dat phong" FontSize="14" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,16"/>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Loai phong" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <ComboBox x:Name="cbRoomType" Height="36" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12,6" SelectionChanged="DataChanged" FontSize="13">
                                    <ComboBoxItem Content="Standard"/>
                                    <ComboBoxItem Content="Deluxe"/>
                                    <ComboBoxItem Content="VIP"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="So phong" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <ComboBox x:Name="cbRoomNumber" Height="36" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12,6" FontSize="13">
                                    <ComboBoxItem Content="101"/>
                                    <ComboBoxItem Content="102"/>
                                    <ComboBoxItem Content="201"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Check-in" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <DatePicker x:Name="dpCheckIn" Height="36" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12,6" SelectedDateChanged="DataChanged" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Check-out" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <DatePicker x:Name="dpCheckOut" Height="36" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12,6" SelectedDateChanged="DataChanged" FontSize="13"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Trang thai" FontSize="11" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <ComboBox x:Name="cbStatus" Height="36" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12,6" FontSize="13">
                                    <ComboBoxItem Content="Pending"/>
                                    <ComboBoxItem Content="Confirmed"/>
                                    <ComboBoxItem Content="Checked In"/>
                                    <ComboBoxItem Content="Cancelled"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- TOTAL PRICE -->
                <Border Grid.Row="1" VerticalAlignment="Bottom" Background="#EEF2FF" CornerRadius="12" Padding="16" Margin="0,0,0,0" BorderBrush="#BFDBFE" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Tong tien" FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox x:Name="txtTotalPrice" Background="Transparent" BorderThickness="0" Text="0" IsReadOnly="True" FontSize="20" FontWeight="Bold" Foreground="#2563EB" Width="160" TextAlignment="Right" VerticalContentAlignment="Center"/>
                            <TextBlock Text=" VND" FontSize="13" Foreground="#64748B" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- BUTTONS -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button x:Name="btnCreate" Content="Tao moi" Width="110" Height="44" Background="#2563EB" Foreground="White" FontWeight="SemiBold" Margin="0,0,10,0" Cursor="Hand" Click="btnCreate_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="btnUpdate" Content="Cap nhat" Width="110" Height="44" Background="#059669" Foreground="White" FontWeight="SemiBold" Margin="0,0,10,0" Cursor="Hand" Click="btnUpdate_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="btnCancelBooking" Content="Huy" Width="110" Height="44" Background="#DC2626" Foreground="White" FontWeight="SemiBold" Margin="0,0,10,0" Cursor="Hand" Click="btnCancelBooking_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="btnConfirmCheckIn" Content="Check-in" Width="110" Height="44" Background="#F59E0B" Foreground="White" FontWeight="SemiBold" Cursor="Hand" Click="btnConfirmCheckIn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>