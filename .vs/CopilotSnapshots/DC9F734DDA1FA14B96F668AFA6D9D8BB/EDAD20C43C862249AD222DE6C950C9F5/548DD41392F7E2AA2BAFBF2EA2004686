        // ================= QR CODE GENERATION =================
        private void GenerateQRCode()
        {
            try
            {
                // Get bill info
                string customerName = txtCustomerName.Text ?? "Hotel Payment";
                string totalAmount = txtTotalPayment.Text ?? "0";
                string billNumber = txtBillNumber.Text ?? "0000";

                // Create QR data
                string qrData = $"BillNo:{billNumber}|Customer:{customerName}|Amount:{totalAmount}VND|Date:{DateTime.Now:yyyy-MM-dd}";

                // Generate QR code image
                Bitmap qrImage = GenerateQRCodeImage(qrData, 280);
                
                if (qrImage != null)
                {
                    imgQRCode.Source = BitmapToImageSource(qrImage);
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("Loi tao ma QR: " + ex.Message);
            }
        }

        // Generate QR code using ZXing library
        private Bitmap GenerateQRCodeImage(string text, int size)
        {
            try
            {
                var writer = new ZXing.BarcodeWriter
                {
                    Format = ZXing.BarcodeFormat.QR_CODE,
                    Options = new ZXing.Common.EncodingOptions
                    {
                        Height = size,
                        Width = size,
                        Margin = 1
                    }
                };

                var bitmap = writer.Write(text);
                return new Bitmap(bitmap);
            }
            catch
            {
                // Fallback: create simple placeholder image if ZXing not available
                return CreatePlaceholderImage(size);
            }
        }

        // Create placeholder image if QR generation fails
        private Bitmap CreatePlaceholderImage(int size)
        {
            Bitmap bmp = new Bitmap(size, size);
            using (Graphics g = Graphics.FromImage(bmp))
            {
                g.Clear(Color.White);
                g.DrawRectangle(Pens.Black, 0, 0, size - 1, size - 1);
                g.DrawString("QR CODE", new Font("Arial", 12), Brushes.Black, 
                    new PointF(size / 4, size / 2 - 20));
                g.DrawString(DateTime.Now.Ticks.ToString().Substring(0, 8), new Font("Arial", 10), 
                    Brushes.Gray, new PointF(size / 4, size / 2 + 20));
            }
            return bmp;
        }

        // Convert Bitmap to BitmapImage
        private BitmapImage BitmapToImageSource(Bitmap bitmap)
        {
            using (MemoryStream memory = new MemoryStream())
            {
                bitmap.Save(memory, System.Drawing.Imaging.ImageFormat.Png);
                memory.Position = 0;
                BitmapImage bitmapImage = new BitmapImage();
                bitmapImage.BeginInit();
                bitmapImage.StreamSource = memory;
                bitmapImage.CacheOption = BitmapCacheOption.OnLoad;
                bitmapImage.EndInit();
                bitmapImage.Freeze();
                return bitmapImage;
            }
        }

