        // ================= QR CODE GENERATION =================
        private void GenerateQRCode()
        {
            try
            {
                // Get bill info
                string customerName = txtCustomerName.Text ?? "Hotel Payment";
                string totalAmount = txtTotalPayment.Text ?? "0";
                string billNumber = txtBillNumber.Text ?? "0000";

                // Create QR code placeholder with bill info
                DrawQRCodePlaceholder(customerName, totalAmount, billNumber);
            }
            catch (Exception ex)
            {
                MessageBox.Show("Loi tao ma QR: " + ex.Message);
            }
        }

        // Draw QR code placeholder with info
        private void DrawQRCodePlaceholder(string customerName, string amount, string billNo)
        {
            try
            {
                int size = 280;
                DrawingVisual dv = new DrawingVisual();
                using (DrawingContext dc = dv.RenderOpen())
                {
                    // White background
                    dc.DrawRectangle(Brushes.White, new Pen(new SolidColorBrush(Color.FromArgb(255, 226, 232, 240)), 1), 
                        new Rect(0, 0, size, size));

                    // Border
                    dc.DrawRectangle(null, new Pen(new SolidColorBrush(Color.FromArgb(255, 37, 99, 235)), 2), 
                        new Rect(10, 10, size - 20, size - 20));

                    // QR pattern (checkerboard)
                    DrawQRPattern(dc, size);

                    // Bill info text
                    FormattedText billText = new FormattedText("Bill: " + billNo,
                        System.Globalization.CultureInfo.CurrentCulture,
                        FlowDirection.LeftToRight,
                        new Typeface("Arial"), 10, Brushes.Black);
                    
                    dc.DrawText(billText, new Point(20, size - 40));

                    // Amount text
                    FormattedText amountText = new FormattedText(amount + " VND",
                        System.Globalization.CultureInfo.CurrentCulture,
                        FlowDirection.LeftToRight,
                        new Typeface("Arial"), 9, new SolidColorBrush(Color.FromArgb(255, 37, 99, 235)));
                    
                    dc.DrawText(amountText, new Point(20, size - 20));
                }

                RenderTargetBitmap rtb = new RenderTargetBitmap(size, size, 96, 96, PixelFormats.Pbgra32);
                rtb.Render(dv);
                rtb.Freeze();

                imgQRCode.Source = rtb;
            }
            catch (Exception ex)
            {
                MessageBox.Show("Loi ve QR code: " + ex.Message);
            }
        }

        // Draw QR-like pattern
        private void DrawQRPattern(DrawingContext dc, int size)
        {
            Random random = new Random(12345); // Fixed seed for consistent pattern
            int cellSize = 8;
            Brush blackBrush = new SolidColorBrush(Color.FromArgb(255, 15, 23, 42));
            Brush whiteBrush = Brushes.White;

            for (int row = 2; row < (size - 40) / cellSize; row++)
            {
                for (int col = 2; col < (size - 40) / cellSize; col++)
                {
                    if (random.Next(2) == 0)
                    {
                        dc.DrawRectangle(blackBrush, null,
                            new Rect(20 + col * cellSize, 30 + row * cellSize, cellSize - 1, cellSize - 1));
                    }
                }
            }

            // Corner markers
            DrawCornerMarker(dc, 20, 30, cellSize, blackBrush);
            DrawCornerMarker(dc, size - 60, 30, cellSize, blackBrush);
            DrawCornerMarker(dc, 20, size - 60, cellSize, blackBrush);
        }

        private void DrawCornerMarker(DrawingContext dc, int x, int y, int size, Brush brush)
        {
            for (int i = 0; i < 7; i++)
            {
                for (int j = 0; j < 7; j++)
                {
                    if (i == 0 || i == 6 || j == 0 || j == 6 || (i > 1 && i < 5 && j > 1 && j < 5))
                    {
                        dc.DrawRectangle(brush, null, new Rect(x + i * size, y + j * size, size - 1, size - 1));
                    }
                }
            }
        }

