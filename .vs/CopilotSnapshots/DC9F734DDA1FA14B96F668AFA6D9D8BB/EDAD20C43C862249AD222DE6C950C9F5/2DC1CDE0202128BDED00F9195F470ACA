<Window x:Class="Duanlamchung.BillPay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:Duanlamchung"
        mc:Ignorable="d"
        Title="Hoa Don / Thanh Toan"
        Height="850"
        Width="1300"
        MinWidth="1100"
        MinHeight="750"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        SnapsToDevicePixels="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            CornerRadius="18"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border CornerRadius="18" Background="#FFFFFF">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26" ShadowDepth="0" Opacity="0.28"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Grid Grid.Row="0" Background="#FFFFFF" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Border Width="28" Height="28" CornerRadius="10" Background="#EEF2FF">
                        <Viewbox Margin="6">
                            <Path Fill="#2563EB" Data="M12,2 L2,7 L2,20 C2,21.1 2.9,22 4,22 L20,22 C21.1,22 22,21.1 22,20 L22,7 L12,2 Z M12,5 L20,9 L20,20 L4,20 L4,9 L12,5 Z"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="Hotel Manager" Foreground="#0F172A" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0"/>
                    <TextBlock Text="Hoa Don" Foreground="#64748B" FontSize="12" Margin="8,1,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Button Width="40" Height="30" Margin="0,0,6,0"
                            Background="#F1F5F9" BorderBrush="#E2E8F0" Foreground="#0F172A"
                            Click="BtnMinimize_Click">
                        <TextBlock Text="-" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Width="40" Height="30"
                            Background="#FEF2F2" BorderBrush="#FECACA" Foreground="#991B1B"
                            Click="BtnClose_Click">
                        <TextBlock Text="X" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="1" Background="#F8FAFC" Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Hoa Don" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Thong tin thanh toan" FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- BILL DISPLAY -->
                <Border Grid.Row="1" Background="White" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Padding="40" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- LEFT: BILL INFO -->
                        <StackPanel Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" VerticalAlignment="Center" Margin="0,0,40,0">
                            <TextBlock Text="Khach hang" FontSize="13" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtCustomerName" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,40" TextWrapping="Wrap"/>

                            <TextBlock Text="So tien phai thanh toan" FontSize="13" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="txtTotalPayment" FontSize="48" FontWeight="Bold" Foreground="#2563EB"/>
                                <TextBlock Text=" VND" FontSize="20" Foreground="#64748B" VerticalAlignment="Bottom" Margin="8,0,0,0"/>
                            </StackPanel>

                            <TextBlock Text="Ma hoa don" FontSize="12" Foreground="#64748B" FontWeight="SemiBold" Margin="0,40,0,6"/>
                            <TextBlock x:Name="txtBillNumber" FontSize="14" Foreground="#0F172A" FontWeight="SemiBold"/>

                            <TextBlock Text="Ngay tao" FontSize="12" Foreground="#64748B" FontWeight="SemiBold" Margin="0,16,0,6"/>
                            <TextBlock x:Name="txtCreateDate" FontSize="13" Foreground="#0F172A"/>
                        </StackPanel>

                        <!-- RIGHT: QR CODE -->
                        <StackPanel Grid.Column="1" Grid.Row="0" Grid.RowSpan="3" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="QR Code thanh toan" FontSize="13" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,12" HorizontalAlignment="Center"/>
                            <Border Width="280" Height="280" CornerRadius="12" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12">
                                <Image x:Name="imgQRCode" Stretch="UniformToFill"/>
                            </Border>
                            <TextBlock Text="Quet ma de thanh toan nhanh" FontSize="11" Foreground="#64748B" Margin="0,12,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- BUTTONS -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnPrint" Content="In hoa don" Width="120" Height="44" Background="#2563EB" Foreground="White" FontWeight="SemiBold" Margin="0,0,10,0" Cursor="Hand" Click="btnPrint_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="btnPay" Content="Thanh toan" Width="120" Height="44" Background="#059669" Foreground="White" FontWeight="SemiBold" Margin="0,0,10,0" Cursor="Hand" Click="btnPay_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="btnCloseWindow" Content="Dong" Width="120" Height="44" Background="#6B7280" Foreground="White" FontWeight="SemiBold" Cursor="Hand" Click="BtnClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
