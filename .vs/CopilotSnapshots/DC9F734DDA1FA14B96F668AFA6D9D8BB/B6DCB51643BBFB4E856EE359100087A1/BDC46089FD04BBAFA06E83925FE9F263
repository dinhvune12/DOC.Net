<Window x:Class="Duanlamchung.danhsachdatphong"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Duanlamchung"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Danh Sách Đặt Phòng"
        Height="750"
        Width="1200"
        MinWidth="1000"
        MinHeight="650"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        SnapsToDevicePixels="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            CornerRadius="18"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border CornerRadius="18" Background="#FFFFFF">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26" ShadowDepth="0" Opacity="0.28"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER BAR -->
            <Grid Grid.Row="0" Background="#FFFFFF" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Border Width="28" Height="28" CornerRadius="10" Background="#EEF2FF">
                        <Viewbox Margin="6">
                            <Path Fill="#2563EB" Data="M12,2 L2,7 L2,20 C2,21.1 2.9,22 4,22 L20,22 C21.1,22 22,21.1 22,20 L22,7 L12,2 Z M12,5 L20,9 L20,20 L4,20 L4,9 L12,5 Z"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="Hotel Manager" Foreground="#0F172A" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0"/>
                    <TextBlock Text="| Danh Sách Đặt Phòng" Foreground="#64748B" FontSize="12" Margin="8,1,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Button Width="40" Height="30" Margin="0,0,6,0"
                            Background="#F1F5F9" BorderBrush="#E2E8F0" Foreground="#0F172A"
                            Click="BtnMinimize_Click">
                        <TextBlock Text="—" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Width="40" Height="30"
                            Background="#FEF2F2" BorderBrush="#FECACA" Foreground="#991B1B"
                            Click="BtnClose_Click">
                        <TextBlock Text="✕" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- MAIN CONTENT -->
            <Border Grid.Row="1" Background="#F8FAFC" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Danh Sách Đặt Phòng" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock Text="Xem, lọc và quản lý tất cả đặt phòng" 
                                   FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- FILTER & SEARCH -->
                    <Border Grid.Row="1" Background="White" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Padding="16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- LEFT: FILTER -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Bộ Lọc" FontSize="12" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,8"/>
                                
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Từ Ngày" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <DatePicker x:Name="DpFrom" Height="32" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="8"/>
                                </StackPanel>

                                <StackPanel Margin="0,8,8,0">
                                    <TextBlock Text="Đến Ngày" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <DatePicker x:Name="DpTo" Height="32" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="8"/>
                                </StackPanel>

                                <StackPanel Margin="0,8,8,0">
                                    <TextBlock Text="Trạng Thái" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="CbStatus" Height="32" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="8" SelectedIndex="0">
                                        <ComboBoxItem Content="Tất cả"/>
                                        <ComboBoxItem Content="Pending"/>
                                        <ComboBoxItem Content="Confirmed"/>
                                        <ComboBoxItem Content="Cancelled"/>
                                        <ComboBoxItem Content="CheckedIn"/>
                                        <ComboBoxItem Content="CheckedOut"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button x:Name="BtnApplyFilter" Content="Áp Dụng"
                                            Background="#2563EB" Foreground="White"
                                            Width="90" Height="32" Margin="0,0,8,0"
                                            Cursor="Hand"
                                            Click="BtnApplyFilter_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button x:Name="BtnClearFilter" Content="Xóa"
                                            Background="#F1F5F9" Foreground="#0F172A"
                                            BorderBrush="#E2E8F0" BorderThickness="1"
                                            Width="90" Height="32"
                                            Cursor="Hand"
                                            Click="BtnClearFilter_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <!-- RIGHT: SEARCH & ACTIONS -->
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Tìm Kiếm" FontSize="12" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,8"/>

                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="Tìm Theo" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="CbSearchBy" Height="32" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="8" SelectedIndex="0">
                                        <ComboBoxItem Content="Tên Khách"/>
                                        <ComboBoxItem Content="CCCD"/>
                                        <ComboBoxItem Content="Số Phòng"/>
                                        <ComboBoxItem Content="Mã Booking"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="Nội Dung" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtSearch" Height="32" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="8,0" VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="BtnSearch" Content="Tìm"
                                            Background="#2563EB" Foreground="White"
                                            Width="90" Height="32" Margin="0,0,8,0"
                                            Cursor="Hand"
                                            Click="BtnSearch_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button x:Name="BtnClearSearch" Content="Xóa"
                                            Background="#F1F5F9" Foreground="#0F172A"
                                            BorderBrush="#E2E8F0" BorderThickness="1"
                                            Width="90" Height="32"
                                            Cursor="Hand"
                                            Click="BtnClearSearch_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                                <TextBlock x:Name="TxtCount" Text="(0 dòng)" Foreground="#64748B" FontSize="11" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- DATGRID -->
                    <Border Grid.Row="2" Background="White" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12">
                        <DataGrid x:Name="DgBookings"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  RowHeight="40"
                                  GridLinesVisibility="None"
                                  AlternationCount="2"
                                  SelectionChanged="DgBookings_SelectionChanged">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#64748B"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="12,0,12,12"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Setter Property="FontSize" Value="12"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.Resources>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="AlternationIndex" Value="1">
                                            <Setter Property="Background" Value="#F9FAFB"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#DBEAFE"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã Booking" Binding="{Binding MaBooking}" Width="80"/>
                                <DataGridTextColumn Header="Khách Hàng" Binding="{Binding TenKhach}" Width="150"/>
                                <DataGridTextColumn Header="CCCD" Binding="{Binding CCCD}" Width="110"/>
                                <DataGridTextColumn Header="Phòng" Binding="{Binding SoPhong}" Width="70"/>
                                <DataGridTextColumn Header="Check-in" Binding="{Binding NgayCheckIn}" Width="110"/>
                                <DataGridTextColumn Header="Check-out" Binding="{Binding NgayCheckOut}" Width="110"/>
                                <DataGridTextColumn Header="Trạng Thái" Binding="{Binding TrangThai}" Width="100"/>
                                <DataGridTextColumn Header="Tổng Tiền" Binding="{Binding TienCoc}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- ACTION BUTTONS -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button x:Name="BtnBack"
                                Content="Quay Lại"
                                Background="#F1F5F9"
                                Foreground="#0F172A"
                                Width="110"
                                Height="40"
                                FontWeight="SemiBold"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                Margin="0,0,12,0"
                                Cursor="Hand"
                                Click="BtnBack_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.94"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BtnRefresh"
                                Content="Làm Mới"
                                Background="#F1F5F9"
                                Foreground="#0F172A"
                                Width="110"
                                Height="40"
                                FontWeight="SemiBold"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                Margin="0,0,12,0"
                                Cursor="Hand"
                                Click="BtnRefresh_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.94"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BtnConfirm"
                                Content="Xác Nhận"
                                Background="#059669"
                                Foreground="White"
                                Width="110"
                                Height="40"
                                FontWeight="SemiBold"
                                BorderBrush="#047857"
                                BorderThickness="1"
                                Margin="0,0,12,0"
                                Cursor="Hand"
                                Click="BtnConfirm_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.94"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BtnCancel"
                                Content="Hủy"
                                Background="#DC2626"
                                Foreground="White"
                                Width="110"
                                Height="40"
                                FontWeight="SemiBold"
                                BorderBrush="#B91C1C"
                                BorderThickness="1"
                                Margin="0,0,12,0"
                                Cursor="Hand"
                                Click="BtnCancel_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.94"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BtnOpenCheckIn"
                                Content="Check-in"
                                Background="#F59E0B"
                                Foreground="White"
                                Width="110"
                                Height="40"
                                FontWeight="SemiBold"
                                BorderBrush="#D97706"
                                BorderThickness="1"
                                Cursor="Hand"
                                Click="BtnOpenCheckIn_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.94"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="10" Margin="0,0,0,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="DANH SÁCH ĐẶT PHÒNG" FontSize="18" FontWeight="Bold" Foreground="#1F2A37"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnBack" Content="Quay lại"
                            Width="90" Height="30" Margin="0,0,6,0"
                            Background="#E5E7EB" Foreground="#111827"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnBack_Click"/>
                    <Button x:Name="BtnRefresh" Content="Làm mới"
                            Width="90" Height="30" Margin="0,0,6,0"
                            Background="#E5E7EB" Foreground="#111827"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnRefresh_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- FILTER + SEARCH -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- FILTER -->
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="BỘ LỌC" FontWeight="Bold" Foreground="#374151"/>

                    <WrapPanel Margin="0,8,0,0">
                        <TextBlock Text="Từ:" VerticalAlignment="Center" Foreground="#374151" Margin="0,0,6,0"/>
                        <DatePicker x:Name="DpFrom" Width="140" Height="28" Margin="0,0,10,0"/>

                        <TextBlock Text="Đến:" VerticalAlignment="Center" Foreground="#374151" Margin="0,0,6,0"/>
                        <DatePicker x:Name="DpTo" Width="140" Height="28"/>
                    </WrapPanel>

                    <WrapPanel Margin="0,8,0,0">
                        <TextBlock Text="Trạng thái:" VerticalAlignment="Center" Foreground="#374151" Margin="0,0,6,0"/>
                        <ComboBox x:Name="CbStatus" Width="150" Height="28" SelectedIndex="0">
                            <ComboBoxItem Content="Tất cả"/>
                            <ComboBoxItem Content="Pending"/>
                            <ComboBoxItem Content="Confirmed"/>
                            <ComboBoxItem Content="Cancelled"/>
                            <ComboBoxItem Content="NoShow"/>
                            <ComboBoxItem Content="CheckedIn"/>
                            <ComboBoxItem Content="CheckedOut"/>
                        </ComboBox>

                        <Button x:Name="BtnApplyFilter" Content="Áp dụng"
                                Width="85" Height="30" Margin="10,0,6,0"
                                Background="#2563EB" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnApplyFilter_Click"/>
                        <Button x:Name="BtnClearFilter" Content="Xóa lọc"
                                Width="85" Height="30"
                                Background="#E5E7EB" Foreground="#111827"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnClearFilter_Click"/>
                    </WrapPanel>
                </StackPanel>

                <!-- SEARCH + ACTION -->
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="TÌM VÀ THAO TÁC" FontWeight="Bold" Foreground="#374151"/>

                    <WrapPanel Margin="0,8,0,0">
                        <ComboBox x:Name="CbSearchBy" Width="120" Height="28" SelectedIndex="0" Margin="0,0,6,0">
                            <ComboBoxItem Content="Tên khách"/>
                            <ComboBoxItem Content="CCCD"/>
                            <ComboBoxItem Content="Số phòng"/>
                            <ComboBoxItem Content="Mã booking"/>
                        </ComboBox>

                        <TextBox x:Name="TxtSearch" Width="190" Height="28"
                                 VerticalContentAlignment="Center" Padding="8,0"
                                 ToolTip="Nhập nội dung cần tìm..."/>

                        <Button x:Name="BtnSearch" Content="Tìm"
                                Width="55" Height="30" Margin="6,0,6,0"
                                Background="#2563EB" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnSearch_Click"/>
                        <Button x:Name="BtnClearSearch" Content="Xóa"
                                Width="55" Height="30"
                                Background="#E5E7EB" Foreground="#111827"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnClearSearch_Click"/>
                    </WrapPanel>

                    <WrapPanel Margin="0,8,0,0">
                        <Button x:Name="BtnConfirm" Content="Xác nhận"
                                Width="90" Height="30" Margin="0,0,6,0"
                                Background="#16A34A" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnConfirm_Click"/>
                        <Button x:Name="BtnCancel" Content="Hủy"
                                Width="70" Height="30" Margin="0,0,6,0"
                                Background="#DC2626" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnCancel_Click"/>
                        <Button x:Name="BtnOpenCheckIn" Content="Mở Check-in"
                                Width="110" Height="30"
                                Background="#F59E0B" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnOpenCheckIn_Click"/>
                    </WrapPanel>

                    <TextBlock x:Name="TxtCount" Text="(0 dòng)" Foreground="#6B7280" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- TABLE -->
        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="8">
            <DataGrid x:Name="DgBookings"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      RowHeight="30"
                      GridLinesVisibility="None"
                      AlternationCount="2"
                      SelectionChanged="DgBookings_SelectionChanged">

                <DataGrid.Resources>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Style.Triggers>
                            <Trigger Property="AlternationIndex" Value="1">
                                <Setter Property="Background" Value="#F9FAFB"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Background" Value="#F3F4F6"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Height" Value="34"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="6,0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã" Binding="{Binding MaBooking}" Width="70"/>
                    <DataGridTextColumn Header="Khách" Binding="{Binding TenKhach}" Width="*"/>
                    <DataGridTextColumn Header="CCCD" Binding="{Binding CCCD}" Width="110"/>
                    <DataGridTextColumn Header="Phòng" Binding="{Binding SoPhong}" Width="55"/>
                    <DataGridTextColumn Header="Check-in" Binding="{Binding NgayCheckIn}" Width="90"/>
                    <DataGridTextColumn Header="Check-out" Binding="{Binding NgayCheckOut}" Width="90"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="90"/>
                    <DataGridTextColumn Header="Cọc" Binding="{Binding TienCoc}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>